{
  "name": "@metron/desktop",
  "version": "0.1.14",
  "description": "Metron personal dashboard desktop app",
  "author": "Simon Risberg",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "predev": "tsc",
    "dev": "concurrently -k -n WEB,ELECTRON,TS -c cyan,yellow,blue \"pnpm --filter=@metron/web dev\" \"wait-on http://localhost:3001 && env -u ELECTRON_RUN_AS_NODE electron . --no-sandbox --no-zygote --disable-dev-shm-usage\" \"tsc -w --preserveWatchOutput\"",
    "compile": "tsc && pnpm --filter=@metron/web build",
    "build": "pnpm run compile && electron-builder",
    "build:dir": "pnpm run compile && electron-builder --dir",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.2",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "dev.metron.app",
    "productName": "Metron",
    "executableName": "metron",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/dist/client",
        "to": "web/dist/client"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "simonri",
      "repo": "metron"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "identity": null
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  }
}
