[Unit]
Description=metron-monitor — activity tracker
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/uv run --directory %h/dev/metron/services/monitor python main.py
Environment=METRON_API_URL=https://vps.tailca3fd9.ts.net
EnvironmentFile=-%h/.config/metron/monitor.env
Restart=on-failure
RestartSec=5

[Install]
WantedBy=graphical-session.target
