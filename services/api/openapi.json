          "currency": {
            "type": "string",
            "maxLength": 3,
            "title": "Currency",
            "description": "ISO 4217 currency code."
          },
          "base_balance": {
            "type": "integer",
            "title": "Base Balance",
            "description": "Starting balance in minor units (cents).",
            "default": 0
          },
          "subtype": {
            "type": "string",
