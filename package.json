{
  "name": "bessel",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "turbo test --parallel",
    "test:watch": "turbo test:watch --parallel",
    "typecheck": "turbo typecheck",
    "dev": "turbo dev --parallel --filter=@bessel/web --filter=@bessel/api --filter=@bessel/worker",
    "dev:web": "turbo dev --filter=@bessel/web --parallel",
    "dev:api": "turbo dev --filter=@bessel/api --parallel",
    "desktop:dev": "pnpm --filter=@bessel/desktop dev",
    "desktop:build": "pnpm --filter=@bessel/desktop build",
    "build": "turbo build --parallel",
    "format": "biome format --write .",
    "cleanup:s3": "bun run scripts/cleanup-s3-files.ts",
    "cleanup:s3:dry-run": "DRY_RUN=true bun run scripts/cleanup-s3-files.ts",
    "update-deps": "bunx npm-check-updates --format group --deep -i -p bun",
    "upgrade": "pnpm update -r --latest -i"
  },
  "dependencies": {
    "@biomejs/biome": "^2.5.3",
    "@tanstack/react-table": "^8.21.3",
    "date-fns": "^4.4.0",
    "emoji-regex": "^10.6.0",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@voidzero-dev/vite-plus-darwin-arm64": "0.2.4",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "date-fns": "^4.4.0",
    "@tanstack/query-core": "5.90.16"
  },
  "pnpm": {
    "overrides": {
      "@tanstack/query-core": "5.96.2",
      "@tanstack/react-query": "5.96.2"
    }
  },
  "packageManager": "pnpm@11.1.1"
}
